risk_log = "ALERT: RISK_SCORE > 90 | ENTITY: 0xAb5... | ACTION: FREEZE"

# FIX: We provide 'gas': 3000000 to prevent the VM from crashing during calculation
tx_hash_add = deployed_ledger.functions.addBlock(risk_log).transact({
    'from': deployer_account,
    'gas': 1000000
})

receipt_add = web3.eth.wait_for_transaction_receipt(tx_hash_add)

print(f"✅ Block Added!")
print(f"   Tx Hash: {tx_hash_add.hex()}")
