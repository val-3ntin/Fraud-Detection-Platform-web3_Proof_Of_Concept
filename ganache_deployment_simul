# 4. Deploy the Contract
print("\n--- Deploying Contract ---")
BankingL1Ledger = web3.eth.contract(abi=contract_abi, bytecode=contract_bytecode)

# Submit the transaction that deploys the contract
tx_hash = BankingL1Ledger.constructor().transact()

# Wait for the transaction to be mined
tx_receipt = web3.eth.wait_for_transaction_receipt(tx_hash)
contract_address = tx_receipt.contractAddress

print(f"✅ Contract Deployed At: {contract_address}")
print(f"   Transaction Hash: {tx_hash.hex()}")
print(f"   Gas Used: {tx_receipt['gasUsed']}")

# Initialize the deployed contract instance
deployed_ledger = web3.eth.contract(address=contract_address, abi=contract_abi)


# --- 🔍 DIAGNOSTIC BLOCK ---
print("\n--- 🔍 DEBUGGING CONTRACT STATE ---")

# 1. Ask the contract: "Who is the authorized validator?"
try:
    owner_on_chain = deployed_ledger.functions.authorizedValidator().call()
    print(f"🔐 Contract's Authorized Owner: {owner_on_chain}")
except Exception as e:
    print(f"⚠️ Could not fetch validator (Contract might be broken): {e}")
    owner_on_chain = None

# 2. Check who YOU are
print(f"👤 Your Python Account:          {deployer_account}")

# 3. Check for mismatch
if owner_on_chain != deployer_account:
    print("\n❌ CRITICAL MISMATCH DETECTED")
    print("The contract owner is NOT your account.")
    print("Possibilities:")
    print("   1. The Solidity Constructor did not set 'msg.sender' correctly.")
    print("   2. You deployed with a different account than you are using now.")
    print("   3. The 'authorizedValidator' variable is empty (0x0000...).")
else:
    print("\n✅ ACCOUNTS MATCH")
    print("The authorization logic is correct. The error might be in the 'addBlock' data validation.")
    
# 4. Check if Genesis Block exists
