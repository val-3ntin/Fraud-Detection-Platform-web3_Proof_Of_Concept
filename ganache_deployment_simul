# 1. Connect to Ganache

ganache_url = "HTTP://127.0.0.1:7545"
web3 = Web3(Web3.HTTPProvider(ganache_url))

if web3.is_connected():
    print("✅ Connected to Ganache")
else:
    print("❌ Failed to connect to Ganache. Check if it is running.")
    exit()

# 2. Account Setup
# We use the first account provided by Ganache to deploy and sign transactions
deployer_account = web3.eth.accounts[0]
web3.eth.default_account = deployer_account
